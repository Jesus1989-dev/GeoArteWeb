# Copia a `.env.local` y usa las mismas credenciales que la app Flutter (SECTEI).
# Dashboard Supabase → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://TU_PROYECTO_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=TU_ANON_PUBLIC_KEY

# URL pública del sitio (registro, verificación de correo, recuperación de contraseña).
# Debe coincidir con Supabase → Authentication → URL Configuration (Site URL + Redirect URLs).
# Si Next usa otro puerto (p. ej. 3001), define aquí http://localhost:3000 para evitar errores al registrarse.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# API pública v1 (Contacto → sección API)
# GEOARTE_API_TOKEN=geoarte_demo_cdmx_2026
# GEOARTE_API_REQUIRE_TOKEN=false

# Opcional: mismo corte de año que Flutter (ANIO_CORTE_METRICAS en SECTEI/.env)
# NEXT_PUBLIC_ANIO_CORTE_METRICAS=2026

# Opcional: scripts del mapa (npm run seed:mapa, npm run sync:mapa)
# SUPABASE_SERVICE_ROLE_KEY=TU_SERVICE_ROLE_KEY
# TRANSPORTE_CAPA_SOURCE=auto
# Login de prueba (mismos nombres que SECTEI/lib/screens/login_screen.dart)
# TEST_LOGIN_AUTORIDAD_EMAIL=
# TEST_LOGIN_AUTORIDAD_PASSWORD=
# TEST_LOGIN_INVESTIGADOR_EMAIL=
# TEST_LOGIN_INVESTIGADOR_PASSWORD=
# TEST_LOGIN_CIUDADANO_EMAIL=
# TEST_LOGIN_CIUDADANO_PASSWORD=
